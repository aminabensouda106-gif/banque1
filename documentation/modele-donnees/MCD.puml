@startuml MCD
top to bottom direction
scale max 3000 width
skinparam shadowing false
skinparam backgroundColor #0F0F14
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 60
skinparam defaultFontSize 12
skinparam ArrowFontSize 10
skinparam padding 12
skinparam arrowColor #BBBBBB

title <color:#FFFFFF>MCD — Modèle conceptuel de données AmanaBank</color>

skinparam entity {
  BackgroundColor #D8CCE8
  BorderColor #4A4A4A
  FontColor #111111
}

skinparam package {
  BackgroundColor #1E1E28
  BorderColor #888888
  FontColor #FFFFFF
}

package "Personnel & accès" #1A1A24 {
  entity "UTILISATEUR" as user {
    * **identifiant**
    --
    nom d'utilisateur
    mot de passe (BCrypt)
    nom complet
    email
    **rôle** (ADMIN / AGENT / CHEF)
    compte actif
    dernière connexion
  }
}

package "Clients & comptes" #1A1A24 {
  entity "CLIENT" as client {
    * **identifiant**
    --
    numéro client
    **CIN**
    nom · prénom
    email · téléphone
    adresse
    statut
    portail activé
    mot de passe portail
  }

  entity "COMPTE" as account {
    * **identifiant**
    --
    numéro compte
    **type** (courant / épargne / pro)
    **statut** (actif / bloqué / clôturé)
    **solde**
    date ouverture
    date clôture
  }
}

package "Opérations financières" #1A1A24 {
  entity "TRANSACTION" as transaction {
    * **identifiant**
    --
    **type** (dépôt / retrait / virement / …)
    **montant**
    date et heure
    description
  }
}

package "Extensions métier" #1A1A24 {
  entity "FACTURIER" as provider {
    * **identifiant**
    --
    code (LYDEC, ONEE…)
    libellé
    catégorie
    actif
  }

  entity "PAIEMENT_FACTURE" as bill {
    * **identifiant**
    --
    référence client
    montant
    date création
  }

  entity "COMMANDE_CHEQUIER" as chq {
    * **identifiant**
    --
    numéro commande
    quantité · format feuillets
    **statut** (PENDING → DELIVERED)
    dates demande / traitement / livraison
  }
}

package "Traçabilité & notifications" #1A1A24 {
  entity "NOTIFICATION" as notif {
    * **identifiant**
    --
    type · titre · message
    lien · lue
    date création
  }

  entity "JOURNAL_AUDIT" as audit {
    * **identifiant**
    --
    action · type entité
    id entité · détails
    date et heure
  }
}

' ── Relations noyau ──
client ||--o{ account : "R1–R2\npossède"
user ||--o{ transaction : "exécute"
account ||--o{ transaction : "source"
account ||--o{ transaction : "destination"

' ── Extensions ──
account ||--o{ bill : "débite via"
provider ||--o{ bill : "concerne"
bill ||--|| transaction : "génère"
client ||--o{ chq : "demande"
account ||--o{ chq : "commande"
user ||--o{ chq : "traite"

' ── Transversal ──
client ||--o{ notif : "reçoit"
user ||--o{ notif : "reçoit"
user ||--o{ audit : "effectue"

' ── Layout ──
user -[hidden]right- client
client -[hidden]right- account
account -[hidden]right- transaction

provider -[hidden]right- bill
bill -[hidden]right- chq

notif -[hidden]right- audit

user -[hidden]down- provider
client -[hidden]down- bill
account -[hidden]down- chq
transaction -[hidden]down- notif

legend bottom right
  |= Règle |= Signification |
  | R1–R2 | 1 client → N comptes ; 1 compte → 1 client |
  | R3–R4 | Solde suffisant · comptes actifs |
  | R12–R14 | Chéquier : workflow sans impact solde |
  | <color:#AAAAAA>User ≠ Client</color> | Personnel agence ≠ client bancaire |
endlegend

@enduml
