@startuml diagramme-classes
left to right direction
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam nodesep 42
skinparam ranksep 55
skinparam linetype ortho
skinparam defaultFontSize 13
skinparam ArrowFontSize 12
skinparam packageStyle rectangle
skinparam padding 8

title Diagramme de classes — domaine métier

package "domain.entity" {
  together {
    class User {
      - username : String
      - role : UserRole
      - fullName : String
    }
    class Client {
      - clientNumber : String
      - cin : String
      - status : ClientStatus
    }
    class Account {
      - accountNumber : String
      - type : AccountType
      - balance : BigDecimal
      - status : AccountStatus
    }
    class Transaction {
      - type : TransactionType
      - amount : BigDecimal
      - executedAt : Instant
    }
    User -[hidden]down- Client
    Client -[hidden]down- Account
    Account -[hidden]down- Transaction
  }

  together {
    class BillProvider {
      - code : String
      - name : String
    }
    class BillPayment {
      - clientReference : String
      - amount : BigDecimal
    }
    class CheckbookOrder {
      - orderNumber : String
      - status : CheckbookOrderStatus
      - sheetCount : CheckbookSheetCount
    }
    class Notification {
      - type : NotificationType
      - title : String
      - read : boolean
    }
    class AuditLog {
      - action : String
      - entityType : String
      - performedAt : Instant
    }
    BillProvider -[hidden]down- BillPayment
    BillPayment -[hidden]down- CheckbookOrder
    CheckbookOrder -[hidden]down- Notification
    Notification -[hidden]down- AuditLog
  }

  User -[hidden]right- BillProvider

  Client "1" o-- "0..*" Account : possède >
  User "1" -- "0..*" Transaction : exécute >
  Account "0..1" -- "0..*" Transaction : source >
  Account "0..1" -- "0..*" Transaction : destination >
  Transaction --> User : executedBy

  Client "1" o-- "0..*" CheckbookOrder : demande >
  Client "1" -- "0..*" Notification : reçoit >
  Account "1" o-- "0..*" BillPayment : paie via >
  Account "1" o-- "0..*" CheckbookOrder : commande >
  BillProvider "1" -- "0..*" BillPayment
  BillPayment "1" -- "1" Transaction : génère >
  User "1" -- "0..*" CheckbookOrder : traite >
  User "1" -- "0..*" AuditLog : effectue >
  User "1" -- "0..*" Notification : reçoit >
  AuditLog --> User : performedBy
}

@enduml
